{
  "name": "taskmaster-backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "migrate": "ts-node -O '{\"module\":\"commonjs\"}' node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "ts-node -O '{\"module\":\"commonjs\"}' node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:rollback",
    "seed": "ts-node -O '{\"module\":\"commonjs\"}' node_modules/knex/bin/cli.js --knexfile knexfile.ts seed:run",
    "migrate:prod": "node node_modules/knex/bin/cli.js --knexfile dist/knexfile.js migrate:latest",
    "seed:prod": "node node_modules/knex/bin/cli.js --knexfile dist/knexfile.js seed:run"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.3.1",
    "fastify": "^5.7.4",
    "fastify-plugin": "^4.5.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "lexorank": "^1.0.5",
    "sqlite3": "^5.1.7",
    "swagger-ui-dist": "^5.31.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.1",
    "nodemon": "^3.1.11",
    "pino-pretty": "^11.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "tar": "^7.5.3"
  }
}
